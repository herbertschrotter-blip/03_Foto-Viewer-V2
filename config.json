{
  "Cache": {
    "CacheFolder": ".cache",
    "UseScanCache": true,
    "VideoMetadataCache": true
  },
  "Paths": {
    "TempFolder": ".temp",
    "RootFolder": "",
    "ThumbsFolder": ".thumbs"
  },
  "Performance": {
    "DeleteJobTimeout": 10,
    "MaxParallelJobs": 8,
    "CacheThumbnails": true,
    "UseParallelProcessing": true,
    "LazyLoading": true
  },
  "FileOperations": {
    "UseRecycleBin": true,
    "ConfirmDelete": true,
    "EnableFlattenAndMove": false,
    "RangeRequestSupport": true,
    "EnableMove": false
  },
  "Features": {
    "LightboxViewer": true,
    "OpenInVLC": false,
    "ArchiveExtensions": [
      ".zip",
      ".rar",
      ".7z",
      ".tar",
      ".gz"
    ],
    "ArchiveAfterExtract": "recycle",
    "ArchiveExtraction": true,
    "CollapsibleFolders": true,
    "KeyboardNavigation": true,
    "VideoThumbnailPreGeneration": false
  },
  "Server": {
    "Host": "localhost",
    "Port": 8888,
    "AutoOpenBrowser": true
  },
  "Media": {
    "MimeTypes": {
      ".jpg": "image/jpeg",
      ".mpeg": "video/mpeg",
      ".webp": "image/webp",
      ".mpg": "video/mpeg",
      ".webm": "video/webm",
      ".flv": "video/x-flv",
      ".mov": "video/quicktime",
      ".jpeg": "image/jpeg",
      ".png": "image/png",
      ".bmp": "image/bmp",
      ".m4v": "video/mp4",
      ".m3u8": "application/vnd.apple.mpegurl",
      ".3gp": "video/3gpp",
      ".gif": "image/gif",
      ".avi": "video/x-msvideo",
      ".ts": "video/mp2t",
      ".wmv": "video/x-ms-wmv",
      ".mkv": "video/x-matroska",
      ".tif": "image/tiff",
      ".mp4": "video/mp4",
      ".tiff": "image/tiff"
    },
    "VideoExtensions": [
      ".mp4",
      ".mov",
      ".avi",
      ".mkv",
      ".webm",
      ".m4v",
      ".wmv",
      ".flv",
      ".mpg",
      ".mpeg",
      ".3gp"
    ],
    "ImageExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp",
      ".gif",
      ".bmp",
      ".tif",
      ".tiff"
    ]
  },
  "UI": {
    "ShowVideoCodec": true,
    "ShowVideoMetadata": true,
    "ThumbnailSize": 200,
    "Theme": "light",
    "FolderPreviewCount": 5,
    "ShowBrowserCompatibility": true,
    "GridColumns": 3,
    "FolderPreviewMode": "folders",
    "DefaultThumbSize": "medium",
    "ShowVideoDuration": true
  },
  "Video": {
    "GIFDuration": 3,
    "ThumbnailFPS": 1,
    "ThumbnailEndPercent": 90,
    "HLSSegmentDuration": 2,
    "GIFFrameRate": 10,
    "ConversionPreset": "slow",
    "ThumbnailQuality": 85,
    "PreviewAsGIF": true,
    "UseHLS": true,
    "ThumbnailStartPercent": 10,
    "GIFLoop": true,
    "HLSPreloadSeconds": 3,
    "ThumbnailCount": 5
  }
}
